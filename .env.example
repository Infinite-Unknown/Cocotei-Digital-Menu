# Cocotei Digital Menu — environment variables
# Copy this file to `.env.local` (which is gitignored) and fill in real values.

# ──────────────────────────────────────────────────────────────
# Supabase (Phase 2)
# ──────────────────────────────────────────────────────────────
# Project URL  — e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — safe to ship to browser. Used for customer-side reads.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER-ONLY. Never commit. Used for admin writes + seed script.
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────
# Stripe (Phase 4)
# ──────────────────────────────────────────────────────────────
# Server-only secret key. Get from Stripe Dashboard → Developers → API keys.
# Use sk_test_… in test mode, sk_live_… in production.
STRIPE_SECRET_KEY=

# Webhook signing secret. From Stripe Dashboard → Developers → Webhooks → your endpoint.
# For local dev, run: stripe listen --forward-to localhost:3030/api/stripe/webhook
# The CLI prints a `whsec_…` secret — paste that here.
STRIPE_WEBHOOK_SECRET=

# (Optional) Override base URL used in Stripe success/cancel redirects.
# Defaults to the request origin. Set this if running behind a tunnel like ngrok.
# NEXT_PUBLIC_BASE_URL=https://cocotei.example.com

# (Optional) Currency code passed to Stripe. Default: myr (Malaysian Ringgit).
# NEXT_PUBLIC_STRIPE_CURRENCY=myr

# (Optional, Phase 5+) Publishable key, only needed if we add Payment Element later.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
